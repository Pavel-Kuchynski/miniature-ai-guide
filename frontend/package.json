{
  "name": "miniature-painting-guide-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "Static frontend (vanilla JS/HTML/CSS) for the AI-powered miniature painting guide generator, built with Vite and hosted on S3.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "test": "vitest run"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.9.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
